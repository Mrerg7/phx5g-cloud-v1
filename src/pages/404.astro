---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ACQUISITION_MAILTO } from '../config/site';
---

<BaseLayout
  title="Page Not Found — phx5g.cloud"
  description="The page you requested could not be found."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center bg-phx-bg">
    <div class="text-center px-6">
      <div class="text-8xl font-display text-phx-cyan mb-4">404</div>
      <h1 class="text-2xl font-semibold text-white mb-4">Page Not Found</h1>
      <p class="text-white/60 mb-8 max-w-md">
        The page you're looking for doesn't exist. Return to the homepage to learn about phx5g.cloud domain
        acquisition.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-8 py-3 bg-white text-phx-bg font-semibold rounded-2xl transition-all hover:bg-white/90"
        >
          Back to Homepage
        </a>
        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex items-center justify-center px-8 py-3 border border-white/20 text-white font-semibold rounded-2xl transition-all hover:bg-white/5"
        >
          Inquire About Domain
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
