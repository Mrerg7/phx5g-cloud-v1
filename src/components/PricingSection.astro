---
import { ACQUISITION_MAILTO, SITE } from '../config/site';
import { PRODUCT_REVIEW } from '../config/structured-data';
---

<section id="pricing" class="max-w-4xl mx-auto px-6 py-20">
  <div class="text-center mb-10">
    <div class="inline-block px-4 py-1 rounded-full bg-emerald-400/10 text-emerald-400 text-xs tracking-[1.5px] font-semibold mb-4">
      PREMIUM ACQUISITION
    </div>
    <h2 class="section-header tracking-[-0.03em]">A strategic local + tech asset.</h2>
  </div>

  <div class="glass rounded-3xl p-10 md:p-14 border border-white/10">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-y-8">
      <div>
        <div class="flex items-baseline gap-x-2">
          <span class="text-6xl md:text-7xl font-semibold tracking-tighter">{SITE.priceDisplay}</span>
          <span class="text-white/50 text-xl">USD</span>
        </div>
        <p class="mt-1 text-white/60">One-time acquisition • Full ownership &amp; instant transfer</p>

        <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
          <div class="flex items-center gap-x-2 text-white/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
            <span>Clean title, ready for transfer</span>
          </div>
          <div class="flex items-center gap-x-2 text-white/70">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
            <span>Escrow.com protected transaction</span>
          </div>
        </div>
      </div>

      <div class="md:text-right">
        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex w-full md:w-auto items-center justify-center px-10 py-4 rounded-3xl bg-white font-semibold text-phx-bg text-lg active:scale-[0.985] transition-all hover:bg-white/90"
        >
          Begin Acquisition
        </a>
        <p class="text-xs text-white/50 mt-3 md:mt-2">Serious buyers only. Flexible terms available.</p>
      </div>
    </div>
  </div>

  <div class="mt-8 grid gap-6 md:grid-cols-2 text-left">
    <div class="glass rounded-2xl p-6 border border-white/10">
      <h3 class="text-sm font-semibold tracking-wide text-white/80 mb-3">Acquisition terms</h3>
      <ul class="space-y-2 text-sm text-white/60">
        <li>Free digital transfer via escrow (no shipping fees)</li>
        <li>Final sale — domain transfers are non-refundable</li>
        <li>Transfer typically completes within 3–10 business days</li>
      </ul>
    </div>

    <div class="glass rounded-2xl p-6 border border-white/10">
      <h3 class="text-sm font-semibold tracking-wide text-white/80 mb-3">Domain assessment</h3>
      <p class="text-sm text-white/60">{PRODUCT_REVIEW.reviewBody}</p>
      <div class="mt-3 flex items-center gap-x-2 text-sm text-emerald-400">
        <span aria-hidden="true">★★★★★</span>
        <span class="text-white/50">5/5 investment-grade domain</span>
      </div>
    </div>
  </div>

  <div class="mt-6 text-center">
    <p class="text-xs text-white/50 max-w-md mx-auto">
      Geo-specific + technology domains with clear commercial intent in high-growth markets like Phoenix offer strong
      brand and investment value.
    </p>
  </div>
</section>
