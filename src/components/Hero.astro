---
import { ACQUISITION_MAILTO, cfImageUrl, CF_IMAGES } from '../config/site';

const heroImage = cfImageUrl(CF_IMAGES.heroImageId);
const heroStyle = `background-image: linear-gradient(rgba(10, 10, 15, 0.68), rgba(10, 10, 15, 0.75)), url('${heroImage}');`;
---

<header class="hero-bg min-h-[100dvh] flex items-center relative pt-20" style={heroStyle}>
  <div class="max-w-5xl mx-auto px-6 pb-16 pt-12 md:pt-8 text-center relative z-10">
    <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 mb-8">
      <div class="w-1.5 h-1.5 bg-phx-cyan rounded-full animate-pulse"></div>
      <span class="text-xs font-semibold tracking-[1.5px] text-white/80">PHOENIX 5G INFRASTRUCTURE</span>
    </div>

    <h1 class="domain-text font-display mb-3 tracking-[-0.07em]">phx5g.cloud</h1>

    <p class="max-w-2xl mx-auto text-3xl md:text-4xl font-light tracking-tight text-white/90 mb-4">
      Phoenix 5G.<br />
      Cloud-native infrastructure.
    </p>

    <p class="max-w-lg mx-auto text-xl text-white/70 mb-10">
      The premier domain for 5G edge computing,<br />
      private networks, and next-gen connectivity in the Valley.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ACQUISITION_MAILTO}
        class="group w-full sm:w-auto inline-flex items-center justify-center gap-x-3 px-9 py-4 text-lg font-semibold rounded-3xl bg-gradient-to-r from-phx-cyan to-phx-purple text-phx-bg hover:brightness-105 active:scale-[0.985] transition-all shadow-xl shadow-phx-cyan/20"
      >
        <span>Secure This Asset</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5 group-hover:translate-x-0.5 transition-transform"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M14 5l7 7-7 7m-4-7h11" />
        </svg>
      </a>
      <a
        href="#positioning"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-x-2 px-8 py-4 text-lg font-medium rounded-3xl border border-white/20 hover:bg-white/5 transition-colors"
      >
        Explore the Opportunity
      </a>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-xs text-white/50">
      <div class="flex items-center gap-x-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7" />
        </svg>
        <span>Instant Transfer</span>
      </div>
      <div>Escrow Protected</div>
      <div>Phoenix Metro Focus</div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 hidden md:block">
    <div class="flex flex-col items-center gap-y-1 text-[10px] tracking-widest text-white/40">
      <div>SCROLL TO BEGIN</div>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 animate-bounce"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </div>
  </div>
</header>
